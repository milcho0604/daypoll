# Postgres (docker-compose)
POSTGRES_USER=whenever
POSTGRES_PASSWORD=whenever
POSTGRES_DB=whenever

# API
API_PORT=3001
DATABASE_URL=postgres://whenever:whenever@127.0.0.1:5433/whenever
CORS_ORIGIN=http://localhost:3000
# 어드민(/admin/*) 접근용. 8자 이상. 없으면 어드민 비활성화(503)
ADMIN_TOKEN=change-me-please-32-or-more-chars

# Web
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001
