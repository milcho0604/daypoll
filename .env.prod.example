# docker-compose.prod.yml 이 읽는 운영 환경변수 템플릿.
#   cp .env.prod.example .env.prod   후 값 채우기.
# ⚠️ .env.prod 는 절대 커밋하지 말 것 (.gitignore 에 포함됨).

POSTGRES_USER=whenever
POSTGRES_PASSWORD=            # 강력한 무작위 값. 예: openssl rand -hex 24
POSTGRES_DB=whenever

# Vercel 프론트 도메인. 끝에 / 없이. 여러 개면 쉼표로 구분.
#   예: https://daypoll.vercel.app,https://your-domain.com
CORS_ORIGIN=https://your-app.vercel.app

# 어드민(/admin/*) 접근 토큰. 32자 이상 무작위. 예: openssl rand -hex 24
ADMIN_TOKEN=

# Sentry 에러 추적 (옵션, 무료 free tier 5K events/월).
# https://sentry.io 가입 → Node.js 프로젝트 생성 → DSN 복사.
# 비워두면 에러 추적 비활성 (안전한 기본값).
SENTRY_DSN=
